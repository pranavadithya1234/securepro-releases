# ==============================================================================
# SecurePro AI Exam Proctoring System - Environment Configuration
# ==============================================================================
# Copy this file to '.env' and fill in your new AWS credentials and S3 bucket name.
# Ensure no leading/trailing spaces or quotes.

# AWS Access Credentials
AWS_ACCESS_KEY_ID=YOUR_NEW_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_NEW_AWS_SECRET_ACCESS_KEY

# AWS Region (e.g. us-east-1, ap-south-1)
AWS_REGION=us-east-1

# S3 Assets Bucket (created by aws-provision.sh)
AWS_S3_BUCKET=securepro-assets-YOUR_UNIQUE_SUFFIX
