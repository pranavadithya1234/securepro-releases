# ==============================================================================
# SecurePro AI Exam Proctoring System - Environment Configuration
# ==============================================================================
# Copy this file to '.env' and fill in your integration credentials.
# Ensure no leading/trailing spaces or quotes.

# AWS Access Credentials
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# AWS Region (e.g. us-east-1, ap-south-1)
AWS_REGION=us-east-1

# S3 Assets Bucket (created by aws-provision.sh)
AWS_S3_BUCKET=securepro-assets-zxyw1y

# Groq AI Configuration
GROQ_API_KEY=YOUR_GROQ_API_KEY

# EmailJS Configuration
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY
EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID

# Gmail SMTP Configuration (Nodemailer fallback)
# Note: For Gmail, use a 16-character App Password generated via your Google Account
SMTP_USER=securepro.kmit@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
